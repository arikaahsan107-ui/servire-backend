PORT=5000
MONGODB_URI=mongodb://localhost:27017/servire
NODE_ENV=development

# JWT Secrets
JWT_ACCESS_SECRET=your_super_secret_jwt_access_key_12345
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_12345
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Mock/Optional SMTP Settings
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=mock_username
EMAIL_PASS=mock_password
EMAIL_FROM=noreply@servire.pk
